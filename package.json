{
  "name": "@nkaaf/azure-iot",
  "description": "Collection of Azure IoT nodes.",
  "version": "1.0.0",
  "license": "Apache-2.0",
  "engines": {
    "node": ">=20"
  },
  "type": "commonjs",
  "files": [
    "dist/",
    "NOTICE",
    "README.md",
    "LICENSE",
    "package.json"
  ],
  "scripts": {
    "clean": "rimraf dist",
    "build": "npm-run-all clean build:runtime build:assets",
    "build:runtime": "tsc --project tsconfig.build.json",
    "build:assets": "cpy \"src/icons/**/*\" dist/azure-iot/icons --parents && cpy \"src/locales/**/*\" dist/azure-iot/locales --parents && cpy \"src/azure-iot/**/*.html\" dist/azure-iot --parents",
    "prepack": "npm run build",
    "nodered": "node-red"
  },
  "dependencies": {
    "@azure/event-hubs": "^6.0.0",
    "azure-iot-device": "^1.18.0",
    "azure-iot-device-amqp": "^1.14.0",
    "azure-iot-device-http": "^1.14.0",
    "azure-iot-device-mqtt": "^1.16.0"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@types/node-red": "^1.3.5",
    "cpy-cli": "^7.0.0",
    "node-red": "^4.1.10",
    "npm-run-all": "^4.1.5",
    "rimraf": "^6.1.3",
    "typescript": "^5.9.3"
  },
  "keywords": [
    "node-red",
    "Azure",
    "IoT",
    "IoTHub",
    "Device",
    "EventHub"
  ],
  "node-red": {
    "nodes": {
      "azure-iot": "dist/azure-iot/azure-iot.js"
    }
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nkaaf/node-red-azure-iot"
  },
  "author": "Niklas Kaaf <nkaaf@protonmail.com>",
  "contributors": [
    "Niklas Kaaf <nkaaf@protonmail.com>"
  ],
  "bugs": {
    "url": "https://github.com/nkaaf/node-red-azure-iot/issues"
  }
}